# Server
PORT=3001

# Postgres connection string
# Example: postgres://USER:PASSWORD@localhost:5432/gamelog
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gamelog

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# IGDB / Twitch credentials (https://dev.twitch.tv/console/apps)
IGDB_CLIENT_ID=your_igdb_client_id_here
IGDB_CLIENT_SECRET=your_igdb_client_secret_here

# CORS: comma-separated list of allowed origins for web
CORS_ORIGINS=http://localhost:8081,http://localhost:3000,http://localhost:19006

# Cloudinary media storage (free, no card) — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Steam Web API key (free, instant) — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key

# The backend URL the phone can actually reach. Steam redirects the in-app
# WebView back here after login, so localhost will NOT work from a device.
# Dev example: http://192.168.1.5:3001
PUBLIC_BASE_URL=
